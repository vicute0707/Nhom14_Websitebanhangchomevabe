spring.application.name=ShopBabyandMomCute

# ==========================================
# SERVER CONFIGURATION
# ==========================================
server.port=8080
server.servlet.session.timeout=30m
server.compression.enabled=true
server.compression.mime-types=text/html,text/xml,text/plain,text/css,text/javascript,application/javascript,application/json

# Base URL cho ứng dụng (dùng cho callback MoMo, link email...)
# Local: http://localhost:8080
# Production: https://your-domain.com
# Ngrok (test webhook): https://your-subdomain.ngrok-free.dev
app.base-url=http://localhost:8080

# ==========================================
# DATABASE CONFIGURATION - MariaDB
# ==========================================
spring.datasource.url=jdbc:mariadb://localhost:3306/shop_me_va_be?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Ho_Chi_Minh
spring.datasource.driver-class-name=org.mariadb.jdbc.Driver
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD

# Connection Pool (HikariCP)
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.connection-timeout=20000
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.max-lifetime=1200000

# ==========================================
# JPA / HIBERNATE CONFIGURATION
# ==========================================
# Dùng 'update' khi dev, 'validate' khi production
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MariaDBDialect
spring.jpa.properties.hibernate.jdbc.time_zone=Asia/Ho_Chi_Minh
spring.jpa.properties.hibernate.jdbc.batch_size=20
spring.jpa.properties.hibernate.order_inserts=true
spring.jpa.properties.hibernate.order_updates=true

# SQL Initialization
spring.jpa.defer-datasource-initialization=true
spring.sql.init.mode=never
# Note: import data.sql thủ công bằng:
# mysql -u root -p shop_me_va_be < src/main/resources/db/data.sql

# ==========================================
# JSP CONFIGURATION
# ==========================================
spring.mvc.view.prefix=/WEB-INF/views/
spring.mvc.view.suffix=.jsp

# ==========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==========================================
# Lấy App Password tại: https://myaccount.google.com/apppasswords
# (Cần bật 2-Step Verification trước)
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=your-email@gmail.com
spring.mail.password=YOUR_GMAIL_APP_PASSWORD_16_CHARS
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.connectiontimeout=5000
spring.mail.properties.mail.smtp.timeout=5000
spring.mail.properties.mail.smtp.writetimeout=5000

# ==========================================
# MOMO PAYMENT GATEWAY
# ==========================================
# Test Environment - lấy key tại: https://business.momo.vn/
momo.endpoint=https://test-payment.momo.vn/v2/gateway/api/create
momo.partner-code=YOUR_MOMO_PARTNER_CODE
momo.access-key=YOUR_MOMO_ACCESS_KEY
momo.secret-key=YOUR_MOMO_SECRET_KEY
momo.redirect-url=${app.base-url}/payment/momo/callback
momo.ipn-url=${app.base-url}/payment/momo/ipn
momo.request-type=captureWallet

# ==========================================
# JWT CONFIGURATION
# ==========================================
# Secret key tối thiểu 32 ký tự (256 bits)
# Tạo random: https://www.allkeysgenerator.com/Random/Security-Encryption-Key-Generator.aspx
jwt.secret=YOUR_JWT_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG_AND_RANDOM
# JWT hết hạn sau 24 giờ (millisecond)
jwt.expiration=86400000

# ==========================================
# CLOUDINARY (Upload ảnh)
# ==========================================
# Đăng ký tại: https://cloudinary.com/
cloudinary.enabled=true
cloudinary.cloud-name=YOUR_CLOUDINARY_CLOUD_NAME
cloudinary.api-key=YOUR_CLOUDINARY_API_KEY
cloudinary.api-secret=YOUR_CLOUDINARY_API_SECRET

# ==========================================
# GEMINI AI CHATBOT
# ==========================================
# Lấy API key tại: https://aistudio.google.com/apikey
gemini.api.key=YOUR_GEMINI_API_KEY
gemini.model=gemini-2.5-flash

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
logging.level.root=INFO
logging.level.iuh.student.www=DEBUG
logging.level.org.springframework.security=DEBUG
logging.level.org.springframework.web=DEBUG
logging.level.org.hibernate.SQL=DEBUG
logging.level.org.hibernate.type.descriptor.sql.BasicBinder=TRACE

# ==========================================
# SECURITY
# ==========================================
spring.security.csrf.cookie.http-only=true
spring.security.csrf.cookie.secure=false

# ==========================================
# ACTUATOR (Health Monitoring)
# ==========================================
management.endpoints.web.exposure.include=health,info,metrics
management.endpoint.health.show-details=when-authorized

# ==========================================
# JACKSON / JSON
# ==========================================
spring.jackson.serialization.write-dates-as-timestamps=false
spring.jackson.time-zone=Asia/Ho_Chi_Minh

# ==========================================
# STATIC RESOURCES
# ==========================================
spring.web.resources.cache.cachecontrol.max-age=3600

# ==========================================
# ERROR HANDLING
# ==========================================
server.error.include-message=always
server.error.include-binding-errors=always
server.error.include-stacktrace=on_param